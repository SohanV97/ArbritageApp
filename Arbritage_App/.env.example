# Copy to .env in this folder (Arbritage_App/.env). Never commit .env.
# app.config.js loads this file explicitly; keys are passed to the app as expo.extra and read in api/kalshi.ts and api/polymarket.ts.
# Kalshi: https://kalshi.com (account → API). Sent as header KALSHI-ACCESS-KEY.
EXPO_PUBLIC_KALSHI_API_KEY=
# Polymarket: CLOB apiKey. Sent as header POLY_API_KEY (optional for Gamma/CLOB read).
EXPO_PUBLIC_POLYMARKET_API_KEY=
