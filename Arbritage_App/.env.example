# Copy this file to .env and fill in your keys. Never commit .env.
# Kalshi: https://kalshi.com (account → API). Sent as KALSHI-ACCESS-KEY when set.
EXPO_PUBLIC_KALSHI_API_KEY=
# Polymarket: from CLOB API credentials (apiKey). Sent as POLY_API_KEY on CLOB requests; read endpoints work without it.
EXPO_PUBLIC_POLYMARKET_API_KEY=
